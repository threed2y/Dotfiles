# ~/.config/ghostty/config

theme = "Catppuccin Mocha"
font-family-bold = "JetBrainsMono Nerd Font"
font-size = 11
minimum-contrast = 5
font-feature = -calt
font-feature = -liga

#shell integration

shell-integration = zsh
command = /usr/bin/zsh

# visuals 

window-padding-x = 10
window-padding-y = 10
window-save-state = always

# shader integration
#custom-shader = ~/.config/ghostty/shaders/just-snow.glsl
custom-shader = /home/ethan/.config/ghostty/shaders/cursor_warp.glsl
custom-shader-animation = always

# background settings

#background-image = /home/ethan/Downloads/kitty.png
background-image-fit = cover
background-image-opacity = 0.3
background-opacity = 0.3
background-blur-radius = 25

window-decoration = none
split-divider-color = "#90EE90"
fullscreen = false
cursor-color = "#f5e0dc"
selection-background = "#45475a"


keybind = ctrl+r=reload_config
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+x=close_tab
keybind = ctrl+shift+p=new_split:up
keybind = ctrl+shift+l=new_split:down
keybind = ctrl+shift+o=new_split:left
keybind = ctrl+shift+k=new_split:right

link-previews = true

# cursor and shell
cursor-style-blink = false
copy-on-select = clipboard

command = /usr/bin/zsh
